---
interface CTASet {
	resume: string;
	contact: string;
	github: string;
}

interface Props {
	eyebrow: string;
	name: string;
	subhead: string;
	valueStatement: string;
	ctas: CTASet;
}

const { eyebrow, name, subhead, valueStatement, ctas } = Astro.props;
---

<header class="hero">
	<p class="eyebrow">{eyebrow}</p>
	<h1>{name}</h1>
	<p class="subhead">{subhead}</p>
	<p class="value">{valueStatement}</p>
	<nav class="cta-row" aria-label="Primary actions">
		<a href={ctas.resume} class="button button-primary">View Resume</a>
		<a href={ctas.contact} class="button button-secondary" target="_blank" rel="noreferrer">Contact Sijae</a>
		<a href={ctas.github} class="text-link" target="_blank" rel="noreferrer">GitHub</a>
	</nav>
</header>

<style>
	.hero {
		padding: 2.4rem;
		border-radius: 1.25rem;
		background:
			radial-gradient(circle at 75% 0%, rgba(81, 156, 151, 0.3), transparent 45%),
			linear-gradient(155deg, rgba(252, 255, 255, 0.9) 10%, rgba(225, 241, 239, 0.86) 100%);
		border: 1px solid rgba(26, 89, 95, 0.24);
		box-shadow: 0 16px 42px rgba(5, 52, 53, 0.15);
		animation: rise 500ms ease-out both;
	}

	.eyebrow {
		margin: 0;
		font-size: 0.79rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--steel);
		font-family: 'Space Grotesk', sans-serif;
	}

	h1 {
		margin: 0.45rem 0 0;
		font-size: clamp(2.4rem, 6.3vw, 4.7rem);
		line-height: 1;
		font-family: 'Space Grotesk', sans-serif;
	}

	.subhead {
		margin: 0.75rem 0 0;
		font-size: clamp(1.12rem, 2.8vw, 1.45rem);
		font-weight: 700;
		line-height: 1.4;
	}

	.value {
		margin: 0.85rem 0 0;
		max-width: 60ch;
		line-height: 1.75;
		color: var(--steel);
	}

	.cta-row {
		display: flex;
		flex-wrap: wrap;
		gap: 0.7rem;
		margin-top: 1.35rem;
	}

	.button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.65rem 1rem;
		font-family: 'Space Grotesk', sans-serif;
		font-weight: 700;
		font-size: 0.95rem;
		border-radius: 0.7rem;
		text-decoration: none;
		transition: transform 180ms ease, box-shadow 180ms ease;
	}

	.button:hover {
		transform: translateY(-2px);
	}

	.button-primary {
		color: #f8fefe;
		background: linear-gradient(115deg, var(--accent) 0%, var(--accent-soft) 100%);
		box-shadow: 0 8px 20px rgba(21, 92, 95, 0.25);
	}

	.button-secondary {
		color: var(--ink);
		background: rgba(255, 255, 255, 0.64);
		border: 1px solid rgba(27, 98, 105, 0.25);
	}

	.text-link {
		align-self: center;
		font-weight: 700;
		color: var(--ink);
		text-underline-offset: 0.22em;
		text-decoration-thickness: 2px;
	}

	@keyframes rise {
		from {
			opacity: 0;
			transform: translateY(10px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@media (max-width: 820px) {
		.hero {
			padding: 1.6rem;
		}
	}
</style>
