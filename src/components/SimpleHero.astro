---
interface Props {
	imageSrc: string;
	imageAlt: string;
	imagePosition?: string;
	greeting: string;
}

const { imageSrc, imageAlt, imagePosition = '50% 50%', greeting } = Astro.props;
---

<section class="hero">
	<img src={imageSrc} alt={imageAlt} style={`object-position: ${imagePosition};`} />
	<p>{greeting}</p>
</section>

<style>
	.hero {
		display: grid;
		grid-template-columns: minmax(0, 1fr);
		gap: 1.05rem;
		height: 100%;
		align-content: center;
	}

	img {
		width: 100%;
		height: clamp(300px, 58svh, 700px);
		object-fit: contain;
	}

	p {
		margin: 0;
		font-size: clamp(1.15rem, 2.1vw, 1.4rem);
		line-height: 1.6;
		width: 100%;
	}

	@media (min-width: 820px) {
		.hero {
			grid-template-columns: minmax(0, 1.08fr) minmax(0, 0.92fr);
			gap: 1.4rem;
			align-items: center;
		}

		img {
			height: clamp(380px, 70svh, 760px);
		}
	}
</style>
