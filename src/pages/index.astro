---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import ImpactCards from '../components/ImpactCards.astro';
import CaseStudyList from '../components/CaseStudyList.astro';
import CTAFooter from '../components/CTAFooter.astro';

const heroImage = {
	src: '/images/hero-placeholder.svg',
	alt: 'Sijae Brown outdoors at golden hour',
};

const greeting = 'Hi, I am Sijae. I love building strong systems and living close to nature.';

const info = {
	title: 'Info',
	intro: 'A few snapshots from the way I live and work.',
};

const infoPhotos = [
	{ src: '/images/info-horse-placeholder.svg', alt: 'Sijae with a horse near a fence line' },
	{ src: '/images/info-dog-placeholder.svg', alt: 'Sijae outdoors with a dog on a trail' },
	{ src: '/images/info-goat-placeholder.svg', alt: 'Sijae by animals in a mountain setting' },
	{ src: '/images/info-ocean-placeholder.svg', alt: 'Sijae near open water after a swim' },
];

const ctaLinks = {
	requestResume: {
		label: 'Request Resume',
		href: 'https://www.linkedin.com/in/sijae-brown-54331489/',
	},
	linkedin: {
		label: 'LinkedIn',
		href: 'https://www.linkedin.com/in/sijae-brown-54331489/',
	},
	github: {
		label: 'GitHub',
		href: 'https://github.com/washed-up-eng',
	},
};

const microcopy = 'Resume available upon request.';

const ctas = {
	resume: ctaLinks.requestResume.href,
	contact: ctaLinks.linkedin.href,
	github: ctaLinks.github.href,
};

const impactCards: { title: string; stat: string; detail: string }[] = [];
const caseStudies: {
	title: string;
	problem: string;
	insight: string;
	systemBuilt: string;
	businessShift: string;
	artifact: string;
}[] = [];
const principles: string[] = [];
---

<Layout title="Sijae Brown | Technical Program Manager" description="Narrative portfolio for startup TPM leadership and execution impact.">
	<main>
		<Hero
			name="Sijae Brown"
			subhead="Technical Product Manager"
			valueStatement="In short, I turn ambiguity into execution, tacit knowledge into systems and ambitious ideas into infrastructure that scales."
			ctas={ctas}
		/>

		<ImpactCards cards={impactCards} />

		<CaseStudyList studies={caseStudies} principles={principles} />

		<CTAFooter
			prompt="If you are hiring a TPM to make high-ambiguity work shippable, let's talk."
			ctas={ctas}
		/>
	</main>
</Layout>

<style>
	main {
		max-width: 1080px;
		margin: 0 auto;
		padding: 3.5rem 1.25rem 5rem;
		display: grid;
		gap: 1.2rem;
	}

	@media (max-width: 820px) {
		main {
			padding-top: 2.5rem;
			gap: 1rem;
		}
	}
</style>
