---
import Layout from '../layouts/Layout.astro';
import SimpleHero from '../components/SimpleHero.astro';
import AboutMeSection from '../components/AboutMeSection.astro';
import WorkingOnSection from '../components/WorkingOnSection.astro';
import BottomCtas from '../components/BottomCtas.astro';

const heroImage = {
	src: '/images/utah_selfie.jpg',
	alt: 'Sijae Brown portrait',
	position: '50% 58%',
};

const greeting = "Hey, I'm Sijae. I'm a Senior Product Manager at Float Health.";

const aboutMe = {
	title: 'About Me',
	body: `Originally from the Ozarks and now based in Boulder, Colorado, I'm an ML researcher turned product person with an education in software engineering. Over the past several years I've helped grow an early-stage product from its scrappy beginnings into a platform supporting thousands of patients and nurses each month.

When I'm not working, I'm usually outside. The mountains have become my home where I get to run trails, climb, ski and find quiet places to reset. My favorite thing, though, is riding horses. I love the slow process of building trust with them over time. Horses have taught me that patience, humility, connection and partnership are not created through force, but through consistently showing up with honesty, vulnerability and openness.`,
};

const aboutImage = {
	src: '/images/mountains.jpg',
	alt: 'Mountain landscape in soft evening light',
};

const workingOn = {
	title: "What I'm working on",
	items: [
		'Experimenting with AI-assisted workflows to build scalable automations',
		'Developing an app to help horse owners detect and better understand lameness in their horses',
		'Training for the Ouray 50 Mile Endurance Run in August 2026',
	],
};

const workImage = {
	src: '/images/me_and_archie.jpg',
	alt: 'Sijae with Archie outdoors',
};

const ctaLinks = {
	requestResume: {
		label: 'Request Resume',
		href: 'https://www.linkedin.com/in/sijae-brown-54331489/',
	},
	linkedin: {
		label: 'LinkedIn',
		href: 'https://www.linkedin.com/in/sijae-brown-54331489/',
	},
	github: {
		label: 'GitHub',
		href: 'https://github.com/washed-up-eng',
	},
};

const microcopy = 'Resume available upon request.';

---

<Layout title="Sijae Brown" description="Narrative portfolio for startup TPM leadership and execution impact.">
	<main>
		<section class="page page-hero">
			<div class="page-inner">
				<SimpleHero
					imageSrc={heroImage.src}
					imageAlt={heroImage.alt}
					imagePosition={heroImage.position}
					greeting={greeting}
				/>
			</div>
		</section>
		<section class="page page-about">
			<div class="page-inner page-about-inner">
				<div class="about-copy-frame">
					<AboutMeSection title={aboutMe.title} body={aboutMe.body} />
				</div>
				<div class="about-photo-frame">
					<img class="about-photo" src={aboutImage.src} alt={aboutImage.alt} loading="lazy" decoding="async" />
				</div>
			</div>
		</section>
		<section class="page page-work">
			<div class="page-inner page-work-inner">
				<WorkingOnSection title={workingOn.title} items={workingOn.items} />
				<div class="page-work-photo-frame">
					<img class="page-work-photo" src={workImage.src} alt={workImage.alt} loading="lazy" decoding="async" />
				</div>
				<div class="page-work-cta">
					<BottomCtas links={ctaLinks} microcopy={microcopy} />
				</div>
			</div>
		</section>
	</main>
</Layout>

<style>
	main {
		height: 100svh;
		height: 100dvh;
		overflow-y: auto;
		scroll-snap-type: y mandatory;
	}

	.page {
		min-height: 100svh;
		min-height: 100dvh;
		scroll-snap-align: start;
		scroll-snap-stop: always;
		padding: clamp(1.2rem, 2.5vw, 2rem) 1.4rem;
		box-sizing: border-box;
	}

	.page-hero {
		display: grid;
		align-items: center;
	}

	.page-about {
		display: grid;
		align-items: center;
	}

	.page-work {
		display: grid;
		padding-top: 1rem;
		padding-bottom: 1rem;
	}

	.page-inner {
		width: 100%;
		max-width: 980px;
		margin: 0 auto;
	}

	.page-hero .page-inner {
		display: grid;
		align-content: center;
		min-height: 100%;
	}

	.page-about-inner {
		display: grid;
		grid-template-columns: minmax(0, 1.08fr) minmax(0, 0.92fr);
		gap: 1.4rem;
		align-content: center;
		align-items: stretch;
		min-height: 100%;
		--about-panel-height: clamp(320px, 54svh, 640px);
	}

	.about-copy-frame,
	.about-photo-frame {
		min-height: var(--about-panel-height);
	}

	.about-copy-frame :global(.about) {
		min-height: 100%;
		box-sizing: border-box;
	}

	.about-photo-frame {
		display: grid;
		place-items: center;
	}

	.about-photo {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.page-work-inner {
		display: grid;
		grid-template-rows: auto minmax(0, 1fr) auto;
		height: 100%;
		gap: 0.45rem;
	}

	.page-work-photo-frame {
		min-height: 0;
		height: 100%;
		overflow: hidden;
	}

	.page-work-photo {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.page-work-cta :global(.bottom-ctas) {
		padding-top: 0;
	}

	@media (max-width: 820px) {
		.page {
			padding: 1rem;
		}

		.page-about-inner {
			grid-template-columns: minmax(0, 1fr);
			gap: 1rem;
			align-content: start;
			--about-panel-height: clamp(220px, 38svh, 360px);
		}

		.page-work-inner {
			gap: 0.4rem;
		}

		.page-work {
			padding-top: 0.8rem;
			padding-bottom: 0.8rem;
		}
	}
</style>
