---
import Layout from '../layouts/Layout.astro';
import SimpleHero from '../components/SimpleHero.astro';
import InfoSection from '../components/InfoSection.astro';
import BottomCtas from '../components/BottomCtas.astro';

const heroImage = {
	src: '/images/hero-placeholder.svg',
	alt: 'Sijae Brown outdoors at golden hour',
};

const greeting = 'Hi, I am Sijae. I love building strong systems and living close to nature.';

const info = {
	title: 'Info',
	intro: 'A few snapshots from the way I live and work.',
};

const infoPhotos = [
	{ src: '/images/info-horse-placeholder.svg', alt: 'Sijae with a horse near a fence line' },
	{ src: '/images/info-dog-placeholder.svg', alt: 'Sijae outdoors with a dog on a trail' },
	{ src: '/images/info-goat-placeholder.svg', alt: 'Sijae by animals in a mountain setting' },
	{ src: '/images/info-ocean-placeholder.svg', alt: 'Sijae near open water after a swim' },
];

const ctaLinks = {
	requestResume: {
		label: 'Request Resume',
		href: 'https://www.linkedin.com/in/sijae-brown-54331489/',
	},
	linkedin: {
		label: 'LinkedIn',
		href: 'https://www.linkedin.com/in/sijae-brown-54331489/',
	},
	github: {
		label: 'GitHub',
		href: 'https://github.com/washed-up-eng',
	},
};

const microcopy = 'Resume available upon request.';

---

<Layout title="Sijae Brown | Technical Program Manager" description="Narrative portfolio for startup TPM leadership and execution impact.">
	<main>
		<SimpleHero imageSrc={heroImage.src} imageAlt={heroImage.alt} greeting={greeting} />
		<InfoSection title={info.title} intro={info.intro} photos={infoPhotos} />
		<BottomCtas links={ctaLinks} microcopy={microcopy} />
	</main>
</Layout>

<style>
	main {
		max-width: 1080px;
		margin: 0 auto;
		padding: 3.5rem 1.25rem 5rem;
		display: grid;
		gap: 1.2rem;
	}

	@media (max-width: 820px) {
		main {
			padding-top: 2.5rem;
			gap: 1rem;
		}
	}
</style>
