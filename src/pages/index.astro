---
import Layout from '../layouts/Layout.astro';
import SimpleHero from '../components/SimpleHero.astro';
import AboutMeSection from '../components/AboutMeSection.astro';
import PhotoMarquee from '../components/PhotoMarquee.astro';
import WorkingOnSection from '../components/WorkingOnSection.astro';
import BottomCtas from '../components/BottomCtas.astro';

const heroImage = {
	src: '/images/me.jpg',
	alt: 'Sijae Brown portrait',
	position: '50% 58%',
};

const greeting = "Hey, I'm Sijae. I'm a Senior Product Manager at Float Health.";

const aboutMe = {
	title: 'About Me',
	body: `Originally from the Ozarks and now based in Boulder, Colorado, I'm an ML researcher turned product person with an education in software engineering. Over the past several years I've helped grow an early-stage product from its scrappy beginnings into a platform supporting thousands of patients and nurses each month.

When I'm not working, I'm usually outside. The mountains have become my home where I get to run trails, climb, ski and find quiet places to reset. My favorite thing, though, is riding horses. I love the slow process of building trust with them over time. Horses have taught me that patience, humility, connection and partnership are not created through force, but through consistently showing up with honesty, vulnerability and openness.`,
};

const marqueePhotos = [
	{ src: '/images/me_and_archie.jpg', alt: 'Sijae and Archie' },
	{ src: '/images/archie.jpg', alt: 'Archie portrait' },
	{ src: '/images/mountains.jpg', alt: 'Mountain landscape' },
	{ src: '/images/mx.jpg', alt: 'Mountain adventure moment', position: '50% 95%' },
	{ src: '/images/mx_p4.jpg', alt: 'Mountain trail snapshot', position: '50% 40%' },
	{ src: '/images/coconut_and_moose.jpg', alt: 'Coconut and Moose' },
	{ src: '/images/me_and_laney.jpg', alt: 'Sijae and Laney', position: '50% 80%' },
	{ src: '/images/vail_ice.jpg', alt: 'Ice route in Vail', position: '50% 20%' },
	{ src: '/images/sharkstooth1.jpg', alt: 'Sharkstooth approach' },
	{ src: '/images/sharkstooth_summit.jpg', alt: 'Sharkstooth summit view' },
	{ src: '/images/france.jpg', alt: 'France travel landscape' },
];

const workingOn = {
	title: "What I'm working on",
	items: [
		'Experimenting with AI-assisted workflows to build scalable automations',
		'Developing an app to help horse owners detect and better understand lameness in their horses',
		'Training for the Ouray 50 Mile Endurance Run in August 2026',
	],
};

const ctaLinks = {
	requestResume: {
		label: 'Request Resume',
		href: 'https://www.linkedin.com/in/sijae-brown-54331489/',
	},
	linkedin: {
		label: 'LinkedIn',
		href: 'https://www.linkedin.com/in/sijae-brown-54331489/',
	},
	github: {
		label: 'GitHub',
		href: 'https://github.com/washed-up-eng',
	},
};

const microcopy = 'Resume available upon request.';

---

<Layout title="Sijae Brown" description="Narrative portfolio for startup TPM leadership and execution impact.">
	<main>
		<SimpleHero
			imageSrc={heroImage.src}
			imageAlt={heroImage.alt}
			imagePosition={heroImage.position}
			greeting={greeting}
		/>
		<AboutMeSection title={aboutMe.title} body={aboutMe.body} />
		<PhotoMarquee photos={marqueePhotos} />
		<WorkingOnSection title={workingOn.title} items={workingOn.items} />
		<BottomCtas links={ctaLinks} microcopy={microcopy} />
	</main>
</Layout>

<style>
	main {
		max-width: 980px;
		margin: 0 auto;
		padding: 4.4rem 1.4rem 6rem;
		display: grid;
		gap: 1.7rem;
	}

	@media (max-width: 820px) {
		main {
			padding-top: 2.4rem;
			padding-bottom: 3.6rem;
			gap: 1.2rem;
		}
	}
</style>
