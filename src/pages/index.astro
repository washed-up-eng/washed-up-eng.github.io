---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import ImpactCards from '../components/ImpactCards.astro';
import CaseStudyList from '../components/CaseStudyList.astro';
import CTAFooter from '../components/CTAFooter.astro';

const ctas = {
	resume: '/resume',
	contact: 'https://www.linkedin.com/in/sijae-brown/',
	github: 'https://github.com/washed-up-eng',
};

const impactCards = [
	{
		title: 'Automation at scale',
		stat: '85%+ visit volume automated',
		detail: 'Led invoicing and payout automation at Float, cutting billing operations time by over 75%.',
	},
	{
		title: 'Clinical platform ownership',
		stat: '100% of visits supported',
		detail: 'Spearheaded zero-to-one eChart development powering all patient visits for the last 3 years.',
	},
	{
		title: 'Execution speed + compliance',
		stat: '8 minutes to seconds',
		detail: 'Led HIPAA-compliant document workflow modernization, dramatically reducing PHI sharing time.',
	},
];

const caseStudies = [
	{
		title: 'Automated Nurse Selector (Float)',
		challenge:
			'Manual nurse assignment was slowing down care coordination and making staffing decisions inconsistent under growth pressure.',
		actions:
			'Defined matching criteria with engineering and operations, drove cross-functional implementation, and established rollout checkpoints with feedback loops.',
		result:
			'Shipped an automated selector that improved assignment consistency and helped teams scale scheduling without increasing operational overhead.',
		artifact: 'Decision framework and matching rules',
	},
	{
		title: 'Document Management v2 (Float)',
		challenge:
			'HIPAA-sensitive document workflows were too slow and error-prone, delaying care operations and raising compliance risk.',
		actions:
			'Led a modernization program across product, engineering, and operations, sequencing milestones and proactively managing launch risks.',
		result:
			'Reduced PHI sharing time from 8 minutes to seconds with a more reliable, auditable workflow for frontline teams.',
		artifact: 'Launch plan and risk register',
	},
	{
		title: 'Invoicing and Payout Automation (Float)',
		challenge:
			'Billing operations depended on repeated manual work that slowed payouts and consumed team bandwidth at high visit volume.',
		actions:
			'Drove automation scope and delivery with engineering and finance stakeholders, then implemented metrics and operational ownership rhythms.',
		result:
			'Automated 85%+ of visit volume and cut billing operations time by over 75%, improving speed and reliability of payouts.',
		artifact: 'Automation dashboard',
	},
];

const principles = [
	'Align quickly, document clearly',
	'De-risk early with milestones',
	'Keep decision logs visible',
	'Balance speed with reliability',
];
---

<Layout title="Sijae Brown | Technical Program Manager" description="Narrative portfolio for startup TPM leadership and execution impact.">
	<main>
		<Hero
			eyebrow="Technical Program Manager"
			name="Sijae Brown"
			subhead="Technical Program Manager for startup execution"
			valueStatement="In short, I turn ambiguity into execution, tribal knowledge into systems, and ambitious ideas into infrastructure that scales."
			ctas={ctas}
		/>

		<ImpactCards cards={impactCards} />

		<CaseStudyList studies={caseStudies} principles={principles} />

		<CTAFooter
			prompt="If you are hiring a TPM to make high-ambiguity work shippable, let's talk."
			ctas={ctas}
		/>
	</main>
</Layout>

<style>
	main {
		max-width: 1080px;
		margin: 0 auto;
		padding: 3.5rem 1.25rem 5rem;
		display: grid;
		gap: 1.2rem;
	}

	@media (max-width: 820px) {
		main {
			padding-top: 2.5rem;
			gap: 1rem;
		}
	}
</style>
